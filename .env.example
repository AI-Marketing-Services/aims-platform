# ============ DATABASE ============
# Neon Postgres via Prisma adapter — both required for pooled + direct
DATABASE_URL="postgresql://user:password@host:5432/aims?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/aims?sslmode=require"
SCOREAPP_WEBHOOK_SECRET=""

# ============ CLERK AUTH ============
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_
CLERK_WEBHOOK_SECRET=whsec_

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/portal/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/portal/dashboard

# ============ STRIPE ============
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ============ AI ============
ANTHROPIC_API_KEY=sk-ant-
GEMINI_API_KEY=

# ============ SEARCH ============
TAVILY_API_KEY=tvly-

# ============ SCRAPING ============
FIRECRAWL_API_KEY=fc-

# ============ EMAIL ============
RESEND_API_KEY=re_
# Comma-separated list of internal addresses that receive application /
# booking / alert notifications. Optional but recommended.
INTERNAL_NOTIFY_TO=
# HMAC secret used to sign one-click unsubscribe tokens in outbound email.
UNSUBSCRIBE_SECRET=

# ============ CACHE ============
UPSTASH_REDIS_REST_URL=https://
UPSTASH_REDIS_REST_TOKEN=

# ============ NOTIFICATIONS ============
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/

# ============ CRON ============
# Required — cron endpoints reject all requests if this is not set
CRON_SECRET=

# ============ BOOTSTRAP ============
# Required to call /api/admin/bootstrap — set a strong random value
BOOTSTRAP_SECRET=
# Comma-separated list of emails that auto-promote to ADMIN on first sign-in
BOOTSTRAP_ADMIN_EMAILS=

# ============ INTEGRATIONS — CRM / PM ============
CLOSE_API_KEY=api_
CLOSE_WEBHOOK_SECRET=
ASANA_PAT=
ASANA_WORKSPACE_GID=
EMAIL_BISON_API_KEY=

# ============ CALENDLY ============
# Booking embed URLs for the two demo flows on /apply
NEXT_PUBLIC_CALENDLY_MATT=
NEXT_PUBLIC_CALENDLY_RYAN=
# Signing secret for the /api/webhooks/calendly endpoint
CALENDLY_WEBHOOK_SECRET=
# REQUIRED — comma-separated allowlist of Calendly event type URIs that
# should trigger the AOC post-booking flow. Team/workspace-level webhooks
# fire for EVERY booking across the workspace, so without this filter the
# AOC welcome email is sent for every sales demo, intern interview, etc.
# Find the URI at Calendly > Event Types > (event) > ... > API URI, e.g.
# https://api.calendly.com/event_types/ABCD1234
# If unset, the webhook skips all bookings (fail-safe).
CALENDLY_AOC_EVENT_TYPE_URIS=

# ============ MIGHTY NETWORKS (AI Operator Collective) ============
# Admin > Settings > API Keys
MIGHTY_API_TOKEN=mn_
MIGHTY_NETWORK_ID=23411751
# Optional HMAC secret for /api/webhooks/mighty
MIGHTY_WEBHOOK_SECRET=
# One-click invite URL surfaced in admin "invite to Mighty" actions
COMMUNITY_INVITE_URL=
NEXT_PUBLIC_COMMUNITY_INVITE_URL=

# ============ DUB.CO (referral short links) ============
DUB_API_KEY=
DUB_WORKSPACE_ID=
DUB_PROGRAM_ID=
DUB_WEBHOOK_SECRET=

# ============ SIGNAL (daily news digest — SMS via Blooio) ============
# https://blooio.com — iMessage/RCS/SMS API. Leave blank to disable SMS delivery.
BLOO_API_KEY=

# ============ LOCKDOWN ============
# Comma-separated Clerk user IDs allowed into protected surfaces.
# Empty = normal role-based auth. Set = only these Clerk users can log in;
# every other authenticated user (including other admins) gets bounced,
# and /sign-up is closed. Public marketing + lead-magnet pages stay open.
LOCKDOWN_ALLOWLIST=

# ============ SENTRY (error monitoring) ============
# DSN is public — safe to expose to the browser. The auth token is NOT and
# must only be set in CI / Vercel for sourcemap uploads.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Optional: opt local dev into Sentry by setting SENTRY_DEV=1.

# ============ APP ============
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ───── Lead Enrichment Pipeline (Scout + Enrich button) ─────
# All four are independently optional — pipeline degrades gracefully if a
# given key is missing (that step no-ops, others still run).
GOOGLE_MAPS_API_KEY=        # Places API (New) v1 — discovery via Scout tool
PERPLEXITY_API_KEY=         # Sonar model — business research
HUNTER_API_KEY=             # domain-search + email-finder
PROSPEO_API_KEY=            # paid company + person enrichment
