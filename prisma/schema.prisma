generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============ USERS & AUTH ============

model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique
  email         String   @unique
  name          String?
  company       String?
  role          UserRole @default(CLIENT)
  avatarUrl     String?
  phone         String?
  industry      String?
  website       String?
  locationCount Int      @default(1)
  heardAbout    String?

  deals                 Deal[]
  subscriptions         Subscription[]
  referralsGiven        Referral[]             @relation("referrer")
  referralReceived      Referral?              @relation("referred")
  leadMagnetSubmissions LeadMagnetSubmission[]
  supportTickets        SupportTicket[]
  internProfile         InternProfile?
  notifications         Notification[]
  emailBisonConnection  EmailBisonConnection?
  opsExcellenceEngagements OpsExcellenceEngagement[]

  stripeCustomerId String?   @unique
  lastLoginAt      DateTime?
  emailNotifs      Boolean   @default(true)
  slackNotifs      Boolean   @default(false)

  // Granular notification preferences
  notifNewPurchase       Boolean @default(true)
  notifFulfillmentUpdate Boolean @default(true)
  notifSupportReply      Boolean @default(true)
  notifBillingAlert      Boolean @default(true)
  notifMarketingDigest   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkId])
  @@index([email])
  @@index([role])
}

enum UserRole {
  CLIENT
  RESELLER
  INTERN
  ADMIN
  SUPER_ADMIN
}

// ============ CRM & DEALS ============

model Deal {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  contactName  String
  contactEmail String
  company      String?
  phone        String?
  industry     String?
  website      String?

  stage    DealStage    @default(APPLICATION_SUBMITTED)
  value    Float        @default(0)
  mrr      Float        @default(0)
  priority DealPriority @default(MEDIUM)

  source       String?
  sourceDetail String?
  channelTag   String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?

  serviceArms DealServiceArm[]
  notes       DealNote[]
  activities  DealActivity[]

  assignedTo String?
  closedAt   DateTime?
  lostReason String?

  leadScore       Int?
  leadScoreTier   String? // 'hot' | 'warm' | 'cold'
  leadScoreReason String? @db.Text

  closeLeadId String? @unique

  mightyInvites      MightyInvite[]
  mightyInviteStatus String?       // 'pending' | 'accepted' | 'failed' | null
  mightyMemberId     Int?          // populated when member joins

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([userId])
  @@index([assignedTo])
  @@index([channelTag])
  @@index([createdAt])
  @@index([mightyInviteStatus])
  @@index([mightyMemberId])
}

enum DealStage {
  APPLICATION_SUBMITTED
  CONSULT_BOOKED
  CONSULT_COMPLETED
  MIGHTY_INVITED
  MEMBER_JOINED
  LOST
}

enum DealPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model DealServiceArm {
  id           String     @id @default(cuid())
  dealId       String
  deal         Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)
  serviceArmId String
  serviceArm   ServiceArm @relation(fields: [serviceArmId], references: [id])
  tier         String?
  monthlyPrice Float?
  status       String     @default("pending")
  activatedAt  DateTime?
  createdAt    DateTime   @default(now())

  @@index([dealId])
  @@index([serviceArmId])
}

model DealNote {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([dealId])
}

model DealActivity {
  id        String       @id @default(cuid())
  dealId    String
  deal      Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type      ActivityType
  detail    String?
  metadata  Json?
  authorId  String?
  createdAt DateTime     @default(now())

  @@index([dealId])
  @@index([type])
  @@index([createdAt])
}

enum ActivityType {
  EMAIL_SENT
  CALL_MADE
  DEMO_COMPLETED
  STAGE_CHANGE
  NOTE_ADDED
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_CANCELLED
  PAYMENT_RECEIVED
  TASK_CREATED
  FORM_SUBMITTED
  MIGHTY_INVITE_SENT
  MIGHTY_INVITE_FAILED
  MIGHTY_INVITE_RESENT
  MIGHTY_MEMBER_JOINED
  MIGHTY_MEMBER_LEFT
  MIGHTY_COURSE_COMPLETED
  MIGHTY_PLAN_PURCHASED
}

model MightyInvite {
  id              String    @id @default(cuid())
  dealId          String
  deal            Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  email           String
  planId          Int
  planName        String?
  mightyInviteId  Int?
  mightyMemberId  Int?
  status          String    @default("pending") // pending | sent | accepted | failed | expired
  errorMessage    String?   @db.Text
  sentAt          DateTime  @default(now())
  acceptedAt      DateTime?
  resentAt        DateTime?
  invitedByClerkId String?
  metadata        Json?

  @@index([dealId])
  @@index([email])
  @@index([status])
  @@index([mightyMemberId])
}

// ============ SERVICES & PRODUCTS ============

model ServiceArm {
  id        String  @id @default(cuid())
  slug      String  @unique
  name      String
  shortDesc String
  longDesc  String? @db.Text

  pillar ServicePillar
  status ServiceStatus @default(COMING_SOON)

  pricingModel PricingModel  @default(MONTHLY)
  basePrice    Float?
  deliveryCost Float?
  tiers        ServiceTier[]

  iconName  String?
  heroImage String?
  demoType  DemoType?
  demoUrl   String?
  features  Json?
  useCases  Json?
  faq       Json?

  deals         DealServiceArm[]
  subscriptions Subscription[]

  sortOrder  Int     @default(0)
  isFeatured Boolean @default(false)

  // Fulfillment config
  defaultAssignee    String?
  setupSteps         Json?
  estimatedSetupDays Int?

  // Asana fulfillment config
  asanaProjectGid      String?
  asanaAssigneeGid     String?
  asanaTaskTemplate    Json? // { name: string, notes: string, subtasks: string[] }
  onboardingFormSchema Json? // Dynamic form fields per service
  ctaUrl               String? // 1:1 button link for this service

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pillar])
  @@index([status])
  @@index([slug])
}

enum ServicePillar {
  MARKETING
  SALES
  OPERATIONS
  FINANCE
}

enum ServiceStatus {
  ACTIVE
  COMING_SOON
  INTERNAL_ONLY
  BETA
  DEPRECATED
}

enum PricingModel {
  MONTHLY
  QUARTERLY
  ONE_TIME
  USAGE_BASED
  CUSTOM
}

enum DemoType {
  INTERACTIVE
  VOICE_PLAYER
  LIVE_TOOL
  VIDEO
  ANIMATED_FLOW
  BEFORE_AFTER
}

model ServiceTier {
  id            String     @id @default(cuid())
  serviceArmId  String
  serviceArm    ServiceArm @relation(fields: [serviceArmId], references: [id], onDelete: Cascade)
  name          String
  slug          String
  price         Float
  interval      String     @default("month")
  stripePriceId String?
  features      Json?
  limits        Json?
  isPopular     Boolean    @default(false)
  sortOrder     Int        @default(0)
  createdAt     DateTime   @default(now())

  @@unique([serviceArmId, slug])
  @@index([serviceArmId])
}

// ============ SUBSCRIPTIONS & BILLING ============

model Subscription {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  serviceArmId String
  serviceArm   ServiceArm @relation(fields: [serviceArmId], references: [id])

  stripeSubId   String?
  stripeCustId  String?
  status        SubStatus @default(ACTIVE)
  tier          String?
  monthlyAmount Float

  fulfillmentStatus  FulfillmentStatus @default(PENDING_SETUP)
  fulfillmentTasks   FulfillmentTask[]
  assignedTeamMember String?

  onboardingData        Json?
  onboardingCompletedAt DateTime?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelledAt           DateTime?
  cancelReason          String?

  opsExcellenceEngagement OpsExcellenceEngagement?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([serviceArmId])
  @@index([status])
  @@index([fulfillmentStatus])
  @@index([stripeSubId])
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
  TRIALING
}

enum FulfillmentStatus {
  PENDING_SETUP
  IN_PROGRESS
  ACTIVE_MANAGED
  NEEDS_ATTENTION
  COMPLETED
  ON_HOLD
}

model FulfillmentTask {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  title       String
  description String?   @db.Text
  status      String    @default("todo")
  assignedTo  String?
  priority    String    @default("medium")
  dueDate     DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subscriptionId])
  @@index([assignedTo])
  @@index([status])
}

// ============ LEAD MAGNETS ============

model LeadMagnetSubmission {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  type    LeadMagnetType
  email   String
  name    String?
  company String?
  phone   String?
  data    Json
  results Json?
  score   Float?

  source      String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  emailSequenceId      String?
  emailSequenceStarted Boolean @default(false)
  convertedToDeal      Boolean @default(false)
  dealId               String?

  createdAt DateTime @default(now())

  @@index([type])
  @@index([email])
  @@index([createdAt])
}

enum LeadMagnetType {
  AI_READINESS_QUIZ
  ROI_CALCULATOR
  WEBSITE_AUDIT
  SEGMENT_EXPLORER
  STACK_CONFIGURATOR
  BUSINESS_CREDIT_SCORE
  EXECUTIVE_OPS_AUDIT
  W2_PLAYBOOK
  BUSINESS_AI_AUDIT
  COLLECTIVE_APPLICATION
  AI_PLAYBOOK
}

// Captures step-1 (name + email) submissions on the apply form so we can
// follow up with anyone who bounced before completing. Upgraded to a full
// LeadMagnetSubmission + Deal when /api/community/apply is POSTed.
model PartialApplication {
  id             String    @id @default(cuid())
  firstName      String
  lastName       String
  email          String
  phone          String?
  source         String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  userAgent      String?
  ip             String?
  completedAt    DateTime?
  reminderSentAt DateTime?
  // Manual-outreach tracking — admins mark these when they call/text a
  // lead whose auto-reminder email still didn't convert them.
  contactedAt    DateTime?
  contactedBy    String?
  contactNote    String?   @db.Text
  dismissedAt    DateTime? // "stop bothering me about this one" toggle
  dealId         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([email])
  @@index([completedAt])
  @@index([reminderSentAt])
  @@index([contactedAt])
  @@index([dismissedAt])
  @@index([createdAt])
}

// ============ REFERRALS & AFFILIATES ============

model Referral {
  id         String  @id @default(cuid())
  referrerId String
  referrer   User    @relation("referrer", fields: [referrerId], references: [id])
  referredId String? @unique
  referred   User?   @relation("referred", fields: [referredId], references: [id])

  code String       @unique
  tier ReferralTier @default(AFFILIATE)

  clicks      Int   @default(0)
  signups     Int   @default(0)
  conversions Int   @default(0)
  totalEarned Float @default(0)

  pendingPayout   Float   @default(0)
  stripeConnectId String?

  landingPageSlug String?

  // Dub.co integration
  dubPartnerId  String?
  dubProgramId  String?
  dubLinkId     String? // Dub.co short link ID for this partner

  commissions Commission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([referrerId])
  @@index([dubPartnerId])
}

enum ReferralTier {
  AFFILIATE
  COMMUNITY_PARTNER
  RESELLER
}

// ============ INTERN OS ============

model InternProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  role   InternRole
  status InternStatus @default(ONBOARDING)
  cohort String?

  tasksCompleted    Int   @default(0)
  revenueAttributed Float @default(0)

  portfolio  String?
  linkedIn   String?
  university String?
  startDate  DateTime?
  endDate    DateTime?

  tasks       InternTask[]
  eodReports  EODReport[]
  sprintGoals SprintGoal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum InternRole {
  AI_BUILDER
  BDR
  PM
  COORDINATOR
}

enum InternStatus {
  APPLIED
  INTERVIEW
  ONBOARDING
  ACTIVE
  PAUSED
  COMPLETED
  REJECTED
}

model InternTask {
  id       String        @id @default(cuid())
  internId String
  intern   InternProfile @relation(fields: [internId], references: [id])

  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    DealPriority @default(MEDIUM)

  linkedProductSlug String?
  linkedDealId      String?
  sprintGoalId      String?
  sprintGoal        SprintGoal? @relation(fields: [sprintGoalId], references: [id])

  estimatedHours Float?
  actualHours    Float?
  revenueImpact  Float?

  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([internId])
  @@index([status])
  @@index([sprintGoalId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
}

model SprintGoal {
  id       String        @id @default(cuid())
  internId String
  intern   InternProfile @relation(fields: [internId], references: [id])

  title     String
  startDate DateTime
  endDate   DateTime
  status    String   @default("active")

  tasks InternTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([internId])
}

model EODReport {
  id       String        @id @default(cuid())
  internId String
  intern   InternProfile @relation(fields: [internId], references: [id])

  completed    Json
  nextPriority Json?
  blockers     Json?
  hoursWorked  Float?

  date      DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([internId])
  @@index([date])
}

// ============ NOTIFICATIONS ============

model Notification {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  channel  NotificationChannel
  type     String
  title    String
  message  String              @db.Text
  metadata Json?
  read     Boolean             @default(false)
  sentAt   DateTime            @default(now())

  @@index([userId])
  @@index([channel])
  @@index([read])
}

enum NotificationChannel {
  IN_APP
  SLACK
  EMAIL
  ALL
}

// ============ SUPPORT ============

model SupportTicket {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  subject  String
  message  String @db.Text
  status   String @default("open")
  priority String @default("normal")

  assignedTo     String?
  resolvedAt     DateTime?
  resolutionNote String?              @db.Text
  replies        SupportTicketReply[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model SupportTicketReply {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  message    String        @db.Text
  isAdmin    Boolean       @default(false)
  authorId   String
  authorName String?
  createdAt  DateTime      @default(now())

  @@index([ticketId])
}

// ============ COMMISSIONS ============

model Commission {
  id              String           @id @default(cuid())
  referralId      String
  referral        Referral         @relation(fields: [referralId], references: [id])
  userId          String
  amount          Float
  percentage      Float
  sourceAmount    Float
  status          CommissionStatus @default(PENDING)
  source          String           @default("internal") // "internal" | "dub"
  stripePaymentId String?
  dubSaleId       String?          // Dub.co sale event ID for correlation
  paidAt          DateTime?
  approvedAt      DateTime?
  approvedBy      String?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([referralId, stripePaymentId])
  @@index([referralId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

// ============ VENDOR TRACKING ============

model VendorTracker {
  id                String   @id @default(cuid())
  vendorName        String
  monthlyCost       Float
  category          String
  currentContract   String?
  replacementName   String?
  replacementStatus String   @default("not_started")
  projectedSavings  Float    @default(0)
  actualSavings     Float    @default(0)
  paybackMonths     Float?
  buildEffortDays   Float?
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============ ANALYTICS ============

model PageView {
  id          String   @id @default(cuid())
  path        String
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  userAgent   String?
  ip          String?
  sessionId   String?
  userId      String?
  createdAt   DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@index([sessionId])
  @@index([userId])
}

model ApiCostLog {
  id         String   @id @default(cuid())
  provider   String
  model      String?
  endpoint   String?
  tokens     Int?
  cost       Float
  serviceArm String?
  clientId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([provider])
  @@index([serviceArm])
  @@index([clientId])
  @@index([createdAt])
}

// ============ WEBHOOK IDEMPOTENCY ============
//
// Every inbound webhook stores its event ID here before processing so that
// provider retries (Calendly 24-hour retry, Stripe exponential backoff,
// Mighty automatic resend) can't double-process and queue duplicate emails
// or activity-log entries.
model WebhookEvent {
  id         String   @id @default(cuid())
  source     String   // "calendly" | "mighty" | "stripe" | "clerk" | "close" | "dub"
  eventUri   String   @unique
  receivedAt DateTime @default(now())

  @@index([source, receivedAt])
}

// ============ EMAIL QUEUE ============

model EmailQueueItem {
  id             String    @id @default(cuid())
  recipientEmail String
  sequenceKey    String
  emailIndex     Int
  scheduledFor   DateTime
  sentAt         DateTime?
  status         String    @default("pending") // pending | sent | failed | cancelled
  metadata       Json?
  // Retry bookkeeping. On transient failures (Resend 5xx / 429 / network)
  // the cron bumps retryCount and pushes scheduledFor out with exponential
  // backoff. Permanent failures (4xx, invalid address) mark status=failed
  // and set lastError so the admin can see why.
  retryCount     Int       @default(0)
  lastError      String?   @db.Text
  lastAttemptAt  DateTime?
  createdAt      DateTime  @default(now())

  @@index([status, scheduledFor])
  @@index([recipientEmail, sequenceKey])
}

// ============ CHAT SESSIONS ============

model ChatSession {
  id           String   @id @default(cuid())
  email        String?
  source       String // "intake", "onboarding", "portal", "marketing"
  clerkUserId  String?
  messages     Json // Store message history
  messageCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@index([source])
  @@index([clerkUserId])
  @@index([createdAt])
}

// ============ EMAIL BISON ============

model EmailBisonConnection {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId   Int
  workspaceName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

// ============ OPERATIONAL EXCELLENCE ============

model OpsExcellenceEngagement {
  id             String @id @default(cuid())
  userId         String
  user           User   @relation(fields: [userId], references: [id])
  subscriptionId String? @unique
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  companyName    String
  companyLogo    String?
  industry       String?
  annualRevenue  String?
  employeeCount  Int?
  website        String?

  stage          EngagementStage @default(INTAKE)
  tier           EngagementTier  @default(DIAGNOSE)

  intakeData        Json?
  callRecordingUrl  String?
  callNotes         Json?

  startDate         DateTime  @default(now())
  targetV1Date      DateTime?
  targetV2Date      DateTime?
  integratorId      String?

  scores            CreditScore[]
  cfoTest           CFOTestResult?
  discoveryCards    ProcessDiscoveryCard[]
  spendDecisions    SpendDecision[]
  automationCards   AutomationCaseCard[]
  capacityPulses    CapacityPulseSurvey[]
  activities        EngagementActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([stage])
  @@index([integratorId])
}

enum EngagementStage {
  INTAKE
  ONBOARDING
  PHASE_1_INSTRUMENT
  PHASE_2_EXECUTE
  PHASE_3_PROVE
  ACTIVE_ONGOING
  PAUSED
  COMPLETED
}

enum EngagementTier {
  DIAGNOSE
  EXECUTE
  PROVE
}

model CreditScore {
  id                String @id @default(cuid())
  engagementId      String
  engagement        OpsExcellenceEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  version           Int
  compositeScore    Float
  confidenceTier    ConfidenceTier
  confidencePercent Float

  financialClarity  Float
  aiReadiness       Float
  capacityRoi       Float
  spendEfficiency   Float

  financialDetail   Json?
  aiReadinessDetail Json?
  capacityRoiDetail Json?
  spendDetail       Json?

  operationalLeverage Float?
  totalHoursFreed     Float?
  totalDollarsSaved   Float?
  automationsDeployed Int?

  calculatedAt DateTime @default(now())
  calculatedBy String?
  notes        String?

  @@index([engagementId])
  @@unique([engagementId, version])
}

enum ConfidenceTier {
  RED
  YELLOW
  GREEN
}

model CFOTestResult {
  id             String @id @default(cuid())
  engagementId   String @unique
  engagement     OpsExcellenceEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  responses      Json
  greenCount     Int
  yellowCount    Int
  redCount       Int

  administeredAt DateTime @default(now())
  administeredBy String?
  notes          String?
}

model ProcessDiscoveryCard {
  id             String @id @default(cuid())
  engagementId   String
  engagement     OpsExcellenceEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  department        String
  processName       String
  ownerRole         String
  frequency         ProcessFrequency
  timePerInstance   Float
  toolsUsed         String[]
  painPoints        String?   @db.Text
  exceptionHandling String?   @db.Text

  automationCandidate AutomationCandidacy @default(MAYBE)
  complexityScore     Int
  valueScore          Int
  tier                Int
  annualCost          Float?

  isExpandedCapture Boolean @default(false)
  expandedContext   Json?

  discoveryRound Int      @default(1)
  validated      Boolean  @default(false)
  validatedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([engagementId])
  @@index([tier])
  @@index([department])
}

enum ProcessFrequency {
  DAILY
  WEEKLY
  MONTHLY
  AD_HOC
}

enum AutomationCandidacy {
  YES
  NO
  MAYBE
}

model SpendDecision {
  id             String @id @default(cuid())
  engagementId   String
  engagement     OpsExcellenceEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  vendorName       String
  toolName         String?
  currentAnnualCost Float
  decision         SpendDecisionType
  newAnnualCost    Float?
  dollarDelta      Float?

  decisionOwner String
  rationale     String?  @db.Text
  renewalDate   DateTime?
  usageLevel    UsageLevel?

  status        SpendDecisionStatus @default(PENDING)
  implementedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([engagementId])
  @@index([status])
}

enum SpendDecisionType {
  ELIMINATE
  CONSOLIDATE
  RENEGOTIATE
  JUSTIFY
}

enum SpendDecisionStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
}

enum UsageLevel {
  HIGH
  MEDIUM
  LOW
  UNKNOWN
}

model AutomationCaseCard {
  id             String @id @default(cuid())
  engagementId   String
  engagement     OpsExcellenceEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  processName            String
  department             String
  roleAffected           String
  fullyLoadedHourlyCost  Float

  baselineTimePerInstance Float
  baselineFrequency       String
  baselineMonthlyHours    Float
  baselineMonthlyCost     Float

  postTimePerInstance Float?
  postMonthlyHours    Float?
  hoursFreedPerMonth  Float?
  dollarValueFreed    Float?

  automationHealthScore Float?
  uptimePercent         Float?
  errorRate             Float?

  deployedAt DateTime?
  measuredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([engagementId])
  @@index([department])
}

model CapacityPulseSurvey {
  id               String @id @default(cuid())
  engagementId     String
  engagement       OpsExcellenceEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  automationCardId String?

  respondentRole     String
  timeSavedPerWeek   Float?
  capacityConversion CapacityConversion
  feedback           String? @db.Text

  submittedAt DateTime @default(now())

  @@index([engagementId])
}

enum CapacityConversion {
  HIGHER_VALUE_WORK
  ABSORBED_NO_CHANGE
  NOT_VISIBLE_YET
}

model EngagementActivity {
  id             String @id @default(cuid())
  engagementId   String
  engagement     OpsExcellenceEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  type     String
  title    String
  detail   String?
  metadata Json?

  createdAt DateTime @default(now())

  @@index([engagementId])
  @@index([createdAt])
}
