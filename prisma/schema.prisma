// ============ MEMBER CRM ============

enum ClientDealStage {
  PROSPECT
  DISCOVERY_CALL
  PROPOSAL_SENT
  ACTIVE_RETAINER
  COMPLETED
  LOST
}

enum ClientActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  PROPOSAL_SENT
  PROPOSAL_ACCEPTED
  PROPOSAL_REJECTED
  STAGE_CHANGE
  CONTACT_ADDED
  INVOICE_SENT
  INVOICE_PAID
  ENRICHMENT_RUN
  FOLLOW_UP_DRAFTED
  FOLLOW_UP_SENT
  // Scorecard-driven activity logging — recorded when an operator
  // bumps the matching scorecard row OR uses the per-deal "log activity"
  // affordance. Distinct enum values so the auto-tally counts them
  // unambiguously without metadata sniffing.
  REFERRAL_ASK_SENT
  DISCOVERY_REQUESTED
  PORTAL_INVITED
  PORTAL_REVOKED
  CONTENT_GENERATED
  FOLLOWUP_TRIGGERED
  ONBOARDING_STEP_COMPLETED
  ONBOARDING_CHECKLIST_STARTED
}

model ClientDeal {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName  String
  contactName  String?
  contactEmail String?
  contactPhone String?
  website      String?
  industry     String?

  // Discovery + enrichment metadata (populated by Scout import + Enrich button)
  googlePlaceId  String?   @unique // dedup imports from Google Places
  lastEnrichedAt DateTime?
  source         String? // "scout" | "manual" | "import" | "audit-converted"

  // Auto-derived priority score (0-100) computed by deriveAutoTags on
  // every enrichment run. null = not yet enriched.
  leadScore Int?

  stage    ClientDealStage @default(PROSPECT)
  value    Float           @default(0)
  currency String          @default("USD")
  notes    String?         @db.Text
  tags     String[]

  // ── Prospecting Activity Tracker fields ──────────────────────────
  // The bottom table on /portal/scorecard pivots ClientDeals onto a
  // single row per prospect with these inline-editable columns. They
  // can be auto-pre-filled from the activity log (e.g. firstMessageAt
  // = first EMAIL activity's createdAt) but the operator's manual
  // input always wins — these fields are the source of truth.
  contactRole     String?
  relationship    String? // "Source / Relationship" column on the sheet
  possibleProblem String?   @db.Text
  outreachType    String? // "email" | "linkedin" | "sms" | "call" | "in-person"
  messageStatus   String? // "drafted" | "sent" | "replied" | "no-reply" | "booked"
  firstMessageAt  DateTime?
  followUp1At     DateTime?
  followUp2At     DateTime?
  discoveryAskAt  DateTime?
  nextAction      String?   @db.Text
  nextActionDueAt DateTime?

  contacts      ClientContact[]
  activities    ClientDealActivity[]
  proposals     ClientProposal[]
  invoices      ClientInvoice[]
  aiScripts     AiScript[]
  portalAccess  ClientPortalAccess[]
  contentPieces ContentPiece[]
  followUpRules FollowUpRule[]
  enrichment    ClientDealEnrichment?
  meetingNotes  ClientDealNote[]

  wonAt      DateTime?
  lostAt     DateTime?
  lostReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, stage])
  @@index([createdAt])
  @@index([lastEnrichedAt])
}

// Stores the structured output of the enrichment pipeline (Website scrape →
// Perplexity → Hunter → Prospeo). One row per ClientDeal — re-enriching
// updates in place, keeps the running history in `sources` JSON.
model ClientDealEnrichment {
  id           String     @id @default(cuid())
  clientDealId String     @unique
  clientDeal   ClientDeal @relation(fields: [clientDealId], references: [id], onDelete: Cascade)

  // Company-level data (Prospeo + Perplexity)
  domain            String?
  description       String? @db.Text
  industry          String?
  employeeCount     Int?
  employeeRange     String?
  revenueRange      String?
  foundedYear       Int?
  city              String?
  state             String?
  country           String?
  linkedinUrl       String?
  twitterUrl        String?
  facebookUrl       String?
  instagramUrl      String?
  logoUrl           String?
  managementCompany String?
  prospeoCompanyId  String? // re-enrich without re-billing

  // Provenance: { website: {found, paths}, perplexity: {...}, hunter: {domainContacts, emailFinder}, prospeo: {company, persons} }
  sources          Json
  totalCreditsCost Int       @default(0)
  startedAt        DateTime
  completedAt      DateTime?
  errorMessage     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClientContact {
  id           String     @id @default(cuid())
  clientDealId String
  clientDeal   ClientDeal @relation(fields: [clientDealId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String?
  title     String?
  email     String?
  phone     String?
  isPrimary Boolean @default(false)
  notes     String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientDealId])
}

// Meeting notes / transcripts / files attached to a ClientDeal — the
// operator's structured context dump. Powers AI follow-ups + proposals
// + future "what was discussed" rollups. Both inline text (pasted
// transcripts, typed notes) and uploaded files (PDFs, audio) live here;
// the `kind` field disambiguates rendering + AI handling.
model ClientDealNote {
  id           String     @id @default(cuid())
  clientDealId String
  clientDeal   ClientDeal @relation(fields: [clientDealId], references: [id], onDelete: Cascade)

  kind     ClientDealNoteKind @default(NOTE)
  title    String? // "Discovery call 4/29", "Proposal feedback PDF"
  content  String?            @db.Text // pasted text / transcript / typed note
  fileUrl  String? // Vercel Blob URL for uploaded files
  fileName String? // original filename for display
  fileSize Int? // bytes
  fileType String? // mime type

  // When the meeting / call occurred — separate from createdAt
  // (createdAt = when uploaded, meetingDate = when it happened).
  meetingDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientDealId])
  @@index([clientDealId, createdAt])
  @@index([meetingDate])
}

enum ClientDealNoteKind {
  NOTE // free-form typed note
  TRANSCRIPT // meeting transcript (pasted)
  RECORDING // audio/video file
  PDF // uploaded PDF
  FILE // any other file
  // Scorecard-driven note kinds — used by the Weekly Prospecting
  // Scorecard's "+1" affordance for the matching rows.
  PROBLEM_HYPOTHESIS
  QUICK_WIN_HYPOTHESIS
}

model ClientDealActivity {
  id           String             @id @default(cuid())
  clientDealId String
  clientDeal   ClientDeal         @relation(fields: [clientDealId], references: [id], onDelete: Cascade)
  type         ClientActivityType
  description  String?            @db.Text
  metadata     Json?

  createdAt DateTime @default(now())

  @@index([clientDealId])
  @@index([createdAt])
}

model ClientProposal {
  id           String     @id @default(cuid())
  clientDealId String
  clientDeal   ClientDeal @relation(fields: [clientDealId], references: [id], onDelete: Cascade)

  title      String
  content    String  @db.Text
  status     String  @default("DRAFT") // DRAFT | SENT | ACCEPTED | REJECTED
  shareToken String? @unique
  totalValue Float   @default(0)
  currency   String  @default("USD")

  generatedAt DateTime  @default(now())
  sentAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientDealId])
  @@index([shareToken])
}

// ============ MEMBER ONBOARDING OS ============

model MemberProfile {
  id           String  @id @default(cuid())
  userId       String  @unique
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName String?
  logoUrl      String?
  oneLiner     String? @db.Text
  niche        String?
  idealClient  String? @db.Text
  businessUrl  String?
  brandColor   String? // hex e.g. "#C4972A"
  tagline      String? // Short tagline for public pages
  faviconUrl   String?
  fontHeading  String? @default("DM Sans")
  accentColor  String? // secondary brand color

  onboardingStartedAt   DateTime  @default(now())
  onboardingCompletedAt DateTime?

  // ── Weekly Prospecting Activity Scorecard config ──────────────────
  // The scorecard is the operator's source of truth — these fields
  // configure the weekly tracker (target multiplier, focus, goal, rule).
  // Per-week manual counts live on OperatorWeeklyScorecard; this row is
  // the persistent global config.
  commitmentLevel     OperatorCommitmentLevel @default(PART_TIME)
  weeklyGoalText      String?                 @default("Create real business conversations")
  weeklyRule          String?                 @default("Do not pitch AI first. Diagnose the business problem.")
  scorecardFocusNiche String? // operator-customisable Focus Niche field on the scorecard header

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum OperatorCommitmentLevel {
  PART_TIME
  FULL_TIME
}

/**
 * One row per operator per ISO week. Stores the operator's MANUAL entries
 * for that week — the scorecard treats the operator's input as the
 * source of truth, so every count, the revenue impact, and the strong
 * opportunities number are stored here. The CRM-derived auto-tally is
 * just a hint surfaced in the UI; if the operator clicks "apply" we
 * copy the value into the matching manual field on this row.
 * `weekStart` is a calendar date (Monday 00:00 in the operator's local
 * timezone, normalised to UTC midnight on that calendar date) so we
 * can use a unique index without TZ ambiguity.
 */
model OperatorWeeklyScorecard {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart DateTime @db.Date

  // ── Per-row manual counts ────────────────────────────────────────
  manualNewProspects       Int @default(0)
  manualOutreachSent       Int @default(0)
  manualFollowUpsSent      Int @default(0)
  manualReferralAsks       Int @default(0)
  manualProblemHypotheses  Int @default(0)
  manualDiscoveryRequested Int @default(0)
  manualDiscoveryBooked    Int @default(0)
  manualDiscoveryCompleted Int @default(0)
  manualQuickWinHypotheses Int @default(0)

  // ── Manual KPIs (no CRM derivation by design) ────────────────────
  // The operator continually updates these as conversations progress.
  revenueImpact       Float @default(0)
  strongOpportunities Int   @default(0)

  // Weekly journal-style notes shown alongside the scorecard.
  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, weekStart])
  @@index([userId, weekStart])
}

model MemberOnboardingStep {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stepKey     String
