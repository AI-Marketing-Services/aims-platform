generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============ USERS & AUTH ============

model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique
  email         String   @unique
  name          String?
  company       String?
  role          UserRole @default(CLIENT)
  avatarUrl     String?
  phone         String?
  industry      String?
  website       String?
  locationCount Int      @default(1)
  heardAbout    String?

  deals                    Deal[]
  referredDeals            Deal[]                    @relation("ReferringReseller")
  subscriptions            Subscription[]
  referralsGiven           Referral[]                @relation("referrer")
  referralReceived         Referral?                 @relation("referred")
  leadMagnetSubmissions    LeadMagnetSubmission[]
  supportTickets           SupportTicket[]
  internProfile            InternProfile?
  notifications            Notification[]
  emailBisonConnection     EmailBisonConnection?
  opsExcellenceEngagements OpsExcellenceEngagement[]
  signalTopics             SignalTopic[]
  signalDigestRuns         SignalDigestRun[]
  ideas                    Idea[]                    @relation("IdeaOwner")
  memberProfile            MemberProfile?
  memberOnboardingSteps    MemberOnboardingStep[]
  weeklyScorecards         OperatorWeeklyScorecard[]
  clientDeals              ClientDeal[]
  usageEvents              UsageEvent[]
  invoices                 ClientInvoice[]           @relation("UserInvoices")
  aiScripts                AiScript[]                @relation("UserAiScripts")
  portalGuests             ClientPortalAccess[]      @relation("OperatorPortalGuests")
  contentPieces            ContentPiece[]            @relation("UserContent")
  followUpRules            FollowUpRule[]            @relation("UserFollowUpRules")
  operatorSite             OperatorSite?
  // Commerce — what this user has bought, what they're entitled to,
  // and (for resellers) the commission ledger they've earned.
  purchases                Purchase[]
  attributedPurchases      Purchase[]                @relation("PurchaseAttribution")
  userEntitlements         Entitlement[]
  commissionsEarned        CommissionEvent[]         @relation("ResellerCommissions")
  portalFeedback           PortalFeedback[]          @relation("PortalFeedbackReporter")
  auditQuizzes             AuditQuiz[]               @relation("AuditQuizOwner")

  stripeCustomerId String?   @unique
  lastLoginAt      DateTime?
  emailNotifs      Boolean   @default(true)
  slackNotifs      Boolean   @default(false)

  // Enrichment credits — denormalized current balance + plan tier; the
  // canonical history lives in the CreditTransaction ledger so we can
  // always reconstruct/audit a balance.
  creditBalance   Int       @default(1000)
  creditPlanTier  String    @default("trial") // trial | operator | pro | agency
  creditGrantedAt DateTime?

  // Active subscription plan slug — references Product.slug for products
  // of type="tier". Drives feature entitlements + monthly credit grants.
  // "free" is the implicit default; webhooks bump this on plan upgrade
  // and revert it on subscription.deleted. Stays in sync with Purchase
  // rows for active recurring subscriptions.
  planSlug           String              @default("free")
  creditTransactions CreditTransaction[]
  operatorEvents     OperatorEvent[]     @relation("OperatorEventActor")

  // Phase-2 productivity features
  templates           UserTemplate[]
  emailSequences      EmailSequence[]
  sequenceEnrollments SequenceEnrollment[]
  clientUpdates       ClientUpdate[]
  callRecordings      CallRecording[]
  bookingAvailability BookingAvailability?
  bookings            Booking[]

  // Granular notification preferences
  notifNewPurchase       Boolean @default(true)
  notifFulfillmentUpdate Boolean @default(true)
  notifSupportReply      Boolean @default(true)
  notifBillingAlert      Boolean @default(true)
  notifMarketingDigest   Boolean @default(false)
  notifSignalDigest      Boolean @default(false)
  signalSmsOptIn         Boolean @default(false)
  signalPhoneE164        String?

  // Quest / achievement system — see lib/quests
  totalXp    Int         @default(0)
  questLevel Int         @default(0) // 0..5 (FOUNDATION → RETENTION)
  userQuests UserQuest[]
  userBadges UserBadge[]
  userStreak UserStreak?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkId])
  @@index([email])
  @@index([role])
}

enum UserRole {
  CLIENT
  RESELLER
  INTERN
  ADMIN
  SUPER_ADMIN
}

// ============ RESELLER WHITELABEL ============

model OperatorSite {
  id                   String   @id @default(cuid())
  userId               String   @unique
  subdomain            String   @unique // e.g. "acme" -> acme.aioperatorcollective.com
  customDomain         String?  @unique
  customDomainVerified Boolean  @default(false)
  vercelDomainData     Json? // cached Vercel API state: verification challenges, DNS config
  isPublished          Boolean  @default(false)
  themeId              String   @default("aoc-default")
  homepageContent      Json     @default("{}")
  seoTitle             String?
  seoDescription       String?
  customCss            String?  @db.Text
  analyticsId          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Whitelabel lead-magnet submissions attributed to this operator site.
  leadSubmissions LeadMagnetSubmission[] @relation("OperatorSubmissions")

  @@index([subdomain])
  @@index([customDomain])
}

// ============ CRM & DEALS ============

model Deal {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // Whitelabel attribution: the reseller whose tenant page drove this lead.
  // Populated by /api/tenant/lead when someone submits a form on a
  // reseller's subdomain or custom domain.
  referringResellerId String?
  referringReseller   User?   @relation("ReferringReseller", fields: [referringResellerId], references: [id])

  contactName  String
  contactEmail String
  company      String?
  phone        String?
  industry     String?
  website      String?

  stage    DealStage    @default(APPLICATION_SUBMITTED)
  value    Float        @default(0)
  mrr      Float        @default(0)
  priority DealPriority @default(MEDIUM)

  source       String?
  sourceDetail String?
  channelTag   String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?

  serviceArms DealServiceArm[]
  notes       DealNote[]
  activities  DealActivity[]

  assignedTo String?
  closedAt   DateTime?
  lostReason String?

  leadScore       Int?
  leadScoreTier   String? // 'hot' | 'warm' | 'cold'
  leadScoreReason String? @db.Text

  closeLeadId String? @unique

  mightyInvites      MightyInvite[]
  mightyInviteStatus String? // 'pending' | 'accepted' | 'failed' | null
  mightyMemberId     Int? // populated when member joins

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([userId])
  @@index([assignedTo])
  @@index([channelTag])
  @@index([createdAt])
  @@index([mightyInviteStatus])
  @@index([mightyMemberId])
  @@index([referringResellerId])
  // Hot lookup path on every Mighty/Close webhook + abandoned-applications
  // cron. The cron uses `mode: "insensitive"` (translates to
  // LOWER(contactEmail) = LOWER(?)) which a plain btree can't accelerate.
  // A separate expression index `LOWER("contactEmail")` is created via raw
  // SQL in prisma/migrations/manual/lower-contact-email.sql — Prisma schema
  // doesn't natively support expression indexes, so we apply that one out
  // of band. The plain @@index here still covers exact-match lookups (Close
  // sync uses raw equality without `mode: insensitive`).
  @@index([contactEmail])
  // Composite for the nurture-unbooked cron's source+stage+createdAt filter.
  @@index([source, stage, createdAt])
}

enum DealStage {
  APPLICATION_SUBMITTED
  CONSULT_BOOKED
  CONSULT_COMPLETED
  MIGHTY_INVITED
  MEMBER_JOINED
  LOST
}

enum DealPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model DealServiceArm {
  id           String     @id @default(cuid())
  dealId       String
  deal         Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)
  serviceArmId String
  serviceArm   ServiceArm @relation(fields: [serviceArmId], references: [id])
  tier         String?
  monthlyPrice Float?
  status       String     @default("pending")
  activatedAt  DateTime?
  createdAt    DateTime   @default(now())

  @@index([dealId])
  @@index([serviceArmId])
}

model DealNote {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([dealId])
}

model DealActivity {
  id        String       @id @default(cuid())
  dealId    String
  deal      Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type      ActivityType
  detail    String?
  metadata  Json?
  authorId  String?
  createdAt DateTime     @default(now())

  @@index([dealId])
  @@index([type])
  @@index([createdAt])
  // Composite for the nurture-unbooked dedup query (`dealId` + `type` +
  // detail LIKE filter). Without this, every deal in the cron loop scans
  // all of its EMAIL_SENT activities.
  @@index([dealId, type])
}

enum ActivityType {
  EMAIL_SENT
  CALL_MADE
  DEMO_COMPLETED
  STAGE_CHANGE
  NOTE_ADDED
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_CANCELLED
  PAYMENT_RECEIVED
  TASK_CREATED
  FORM_SUBMITTED
  MIGHTY_INVITE_SENT
  MIGHTY_INVITE_FAILED
  MIGHTY_INVITE_RESENT
  MIGHTY_MEMBER_JOINED
  MIGHTY_MEMBER_LEFT
  MIGHTY_COURSE_COMPLETED
  MIGHTY_PLAN_PURCHASED
  ONBOARDING_STEP_COMPLETED
  ONBOARDING_STEP_RESET
  MEMBER_PROFILE_UPDATED
}

model MightyInvite {
  id               String    @id @default(cuid())
  dealId           String
  deal             Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  email            String
  planId           Int
  planName         String?
  mightyInviteId   Int?
  mightyMemberId   Int?
  status           String    @default("pending") // pending | sent | accepted | failed | expired
  errorMessage     String?   @db.Text
  sentAt           DateTime  @default(now())
  acceptedAt       DateTime?
  resentAt         DateTime?
  invitedByClerkId String?
  metadata         Json?

  @@index([dealId])
  @@index([email])
  @@index([status])
  @@index([mightyMemberId])
}

// ============ SERVICES & PRODUCTS ============

model ServiceArm {
  id        String  @id @default(cuid())
  slug      String  @unique
  name      String
  shortDesc String
  longDesc  String? @db.Text

  pillar ServicePillar
  status ServiceStatus @default(COMING_SOON)

  pricingModel PricingModel  @default(MONTHLY)
  basePrice    Float?
  deliveryCost Float?
  tiers        ServiceTier[]

  iconName  String?
  heroImage String?
  demoType  DemoType?
  demoUrl   String?
  features  Json?
  useCases  Json?
  faq       Json?

  deals         DealServiceArm[]
  subscriptions Subscription[]

  sortOrder  Int     @default(0)
  isFeatured Boolean @default(false)

  // Fulfillment config
  defaultAssignee    String?
  setupSteps         Json?
  estimatedSetupDays Int?

  // Asana fulfillment config
  asanaProjectGid      String?
  asanaAssigneeGid     String?
  asanaTaskTemplate    Json? // { name: string, notes: string, subtasks: string[] }
  onboardingFormSchema Json? // Dynamic form fields per service
  ctaUrl               String? // 1:1 button link for this service

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pillar])
  @@index([status])
  @@index([slug])
}

enum ServicePillar {
  MARKETING
  SALES
  OPERATIONS
  FINANCE
}

enum ServiceStatus {
  ACTIVE
  COMING_SOON
  INTERNAL_ONLY
  BETA
  DEPRECATED
}

enum PricingModel {
  MONTHLY
  QUARTERLY
  ONE_TIME
  USAGE_BASED
  CUSTOM
}

enum DemoType {
  INTERACTIVE
  VOICE_PLAYER
  LIVE_TOOL
  VIDEO
  ANIMATED_FLOW
  BEFORE_AFTER
}

model ServiceTier {
  id            String     @id @default(cuid())
  serviceArmId  String
  serviceArm    ServiceArm @relation(fields: [serviceArmId], references: [id], onDelete: Cascade)
  name          String
  slug          String
  price         Float
  interval      String     @default("month")
  stripePriceId String?
  features      Json?
  limits        Json?
  isPopular     Boolean    @default(false)
  sortOrder     Int        @default(0)
  createdAt     DateTime   @default(now())

  @@unique([serviceArmId, slug])
  @@index([serviceArmId])
}

// ============ SUBSCRIPTIONS & BILLING ============

model Subscription {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  serviceArmId String
  serviceArm   ServiceArm @relation(fields: [serviceArmId], references: [id])

  stripeSubId   String?
  stripeCustId  String?
  status        SubStatus @default(ACTIVE)
  tier          String?
  monthlyAmount Float

  fulfillmentStatus  FulfillmentStatus @default(PENDING_SETUP)
  fulfillmentTasks   FulfillmentTask[]
  assignedTeamMember String?

  onboardingData        Json?
  onboardingCompletedAt DateTime?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelledAt           DateTime?
  cancelReason          String?

  opsExcellenceEngagement OpsExcellenceEngagement?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([serviceArmId])
  @@index([status])
  @@index([fulfillmentStatus])
  @@index([stripeSubId])
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
  TRIALING
}

enum FulfillmentStatus {
  PENDING_SETUP
  IN_PROGRESS
  ACTIVE_MANAGED
  NEEDS_ATTENTION
  COMPLETED
  ON_HOLD
}

model FulfillmentTask {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  title       String
  description String?   @db.Text
  status      String    @default("todo")
  assignedTo  String?
  priority    String    @default("medium")
  dueDate     DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subscriptionId])
  @@index([assignedTo])
  @@index([status])
}

// ============ LEAD MAGNETS ============

model LeadMagnetSubmission {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // Whitelabel attribution: when an operator drives a prospect to a tool
  // hosted on their subdomain or custom domain, the resulting submission
  // is tagged with that operator's site id. The auto-created Deal is
  // routed into THEIR pipeline (operatorUserId) rather than the platform's.
  operatorId     String?
  operatorSite   OperatorSite? @relation("OperatorSubmissions", fields: [operatorId], references: [id], onDelete: SetNull)
  // Cached for fast queries on the operator's own dashboard without
  // joining through OperatorSite. Populated by the submit endpoint.
  operatorUserId String?

  type    LeadMagnetType
  email   String
  name    String?
  company String?
  phone   String?
  data    Json
  results Json?
  score   Float?

  source      String? // "platform" | "owned-domain" | "outbound" | tool slug
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  emailSequenceId      String?
  emailSequenceStarted Boolean @default(false)
  convertedToDeal      Boolean @default(false)
  dealId               String?

  createdAt DateTime @default(now())

  @@index([type])
  @@index([email])
  @@index([createdAt])
  @@index([operatorId])
  @@index([operatorUserId])
}

enum LeadMagnetType {
  AI_READINESS_QUIZ
  ROI_CALCULATOR
  WEBSITE_AUDIT
  SEGMENT_EXPLORER
  STACK_CONFIGURATOR
  BUSINESS_CREDIT_SCORE
  EXECUTIVE_OPS_AUDIT
  W2_PLAYBOOK
  BUSINESS_AI_AUDIT
  COLLECTIVE_APPLICATION
  AI_PLAYBOOK
  DAILY_SIGNAL
}

// Captures step-1 (name + email) submissions on the apply form so we can
// follow up with anyone who bounced before completing. Upgraded to a full
// LeadMagnetSubmission + Deal when /api/community/apply is POSTed.
model PartialApplication {
  id             String    @id @default(cuid())
  firstName      String
  lastName       String
  email          String
  phone          String?
  source         String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  userAgent      String?
  ip             String?
  completedAt    DateTime?
  reminderSentAt DateTime?
  // Manual-outreach tracking — admins mark these when they call/text a
  // lead whose auto-reminder email still didn't convert them.
  contactedAt    DateTime?
  contactedBy    String?
  contactNote    String?   @db.Text
  dismissedAt    DateTime? // "stop bothering me about this one" toggle
  dealId         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([email])
  @@index([completedAt])
  @@index([reminderSentAt])
  @@index([contactedAt])
  @@index([dismissedAt])
  @@index([createdAt])
}

// ============ REFERRALS & AFFILIATES ============

model Referral {
  id         String  @id @default(cuid())
  referrerId String
  referrer   User    @relation("referrer", fields: [referrerId], references: [id])
  referredId String? @unique
  referred   User?   @relation("referred", fields: [referredId], references: [id])

  code String       @unique
  tier ReferralTier @default(AFFILIATE)

  clicks      Int   @default(0)
  signups     Int   @default(0)
  conversions Int   @default(0)
  totalEarned Float @default(0)

  pendingPayout   Float   @default(0)
  stripeConnectId String?

  landingPageSlug String?

  // Dub.co integration
  dubPartnerId String?
  dubProgramId String?
  dubLinkId    String? // Dub.co short link ID for this partner

  commissions Commission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([referrerId])
  @@index([dubPartnerId])
}

enum ReferralTier {
  AFFILIATE
  COMMUNITY_PARTNER
  RESELLER
}

// ============ INTERN OS ============

model InternProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  role   InternRole
  status InternStatus @default(ONBOARDING)
  cohort String?

  tasksCompleted    Int   @default(0)
  revenueAttributed Float @default(0)

  portfolio  String?
  linkedIn   String?
  university String?
  startDate  DateTime?
  endDate    DateTime?

  tasks       InternTask[]
  eodReports  EODReport[]
  sprintGoals SprintGoal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum InternRole {
  AI_BUILDER
  BDR
  PM
  COORDINATOR
}

enum InternStatus {
  APPLIED
  INTERVIEW
  ONBOARDING
  ACTIVE
  PAUSED
  COMPLETED
  REJECTED
}

model InternTask {
  id       String        @id @default(cuid())
  internId String
  intern   InternProfile @relation(fields: [internId], references: [id])

  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    DealPriority @default(MEDIUM)

  linkedProductSlug String?
  linkedDealId      String?
  sprintGoalId      String?
  sprintGoal        SprintGoal? @relation(fields: [sprintGoalId], references: [id])

  estimatedHours Float?
  actualHours    Float?
  revenueImpact  Float?

  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([internId])
  @@index([status])
  @@index([sprintGoalId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
}

model SprintGoal {
  id       String        @id @default(cuid())
  internId String
  intern   InternProfile @relation(fields: [internId], references: [id])

  title     String
  startDate DateTime
  endDate   DateTime
  status    String   @default("active")

  tasks InternTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([internId])
}

model EODReport {
  id       String        @id @default(cuid())
  internId String
  intern   InternProfile @relation(fields: [internId], references: [id])

  completed    Json
  nextPriority Json?
  blockers     Json?
  hoursWorked  Float?

  date      DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([internId])
  @@index([date])
}

// ============ NOTIFICATIONS ============

model Notification {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  channel  NotificationChannel
  type     String
  title    String
  message  String              @db.Text
  metadata Json?
  read     Boolean             @default(false)
  sentAt   DateTime            @default(now())

  @@index([userId])
  @@index([channel])
  @@index([read])
}

enum NotificationChannel {
  IN_APP
  SLACK
  EMAIL
  ALL
}

// ============ SUPPORT ============

model SupportTicket {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  subject  String
  message  String @db.Text
  status   String @default("open")
  priority String @default("normal")

  assignedTo     String?
  resolvedAt     DateTime?
  resolutionNote String?              @db.Text
  replies        SupportTicketReply[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model SupportTicketReply {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  message    String        @db.Text
  isAdmin    Boolean       @default(false)
  authorId   String
  authorName String?
  createdAt  DateTime      @default(now())

  @@index([ticketId])
}

// ============ COMMISSIONS ============

model Commission {
  id              String           @id @default(cuid())
  referralId      String
  referral        Referral         @relation(fields: [referralId], references: [id])
  userId          String
  amount          Float
  percentage      Float
  sourceAmount    Float
  status          CommissionStatus @default(PENDING)
  source          String           @default("internal") // "internal" | "dub"
  stripePaymentId String?
  dubSaleId       String? // Dub.co sale event ID for correlation
  paidAt          DateTime?
  approvedAt      DateTime?
  approvedBy      String?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([referralId, stripePaymentId])
  @@index([referralId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

// ============ VENDOR TRACKING ============

model VendorTracker {
  id                String   @id @default(cuid())
  vendorName        String
  monthlyCost       Float
  category          String
  currentContract   String?
  replacementName   String?
  replacementStatus String   @default("not_started")
  projectedSavings  Float    @default(0)
  actualSavings     Float    @default(0)
  paybackMonths     Float?
  buildEffortDays   Float?
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============ ANALYTICS ============

model PageView {
  id          String   @id @default(cuid())
  path        String
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  userAgent   String?
  ip          String?
  sessionId   String?
  userId      String?
  createdAt   DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@index([sessionId])
  @@index([userId])
}

// ============ UTM LINK TRACKING ============

model UtmLink {
  id          String   @id @default(cuid())
  name        String // human-readable label e.g. "LinkedIn Bio — April Launch"
  baseUrl     String   @default("https://aioperatorcollective.com/apply")
  channel     String // linkedin | twitter | instagram | email | youtube | tiktok | podcast | newsletter | sms | other
  utmSource   String
  utmMedium   String
  utmCampaign String
  utmContent  String?
  utmTerm     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([utmSource])
  @@index([utmCampaign])
