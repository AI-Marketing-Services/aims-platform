// by scripts/ingest-mighty.ts and the /api/cron/ingest-mighty endpoint.

model KnowledgeEntry {
  id       String @id @default(cuid())
  // "mighty:post", "mighty:coursework", "mighty:event" — whatever shape
  // future sources take (docs, public FAQ, etc.) they get their own
  // source prefix so the unique constraint below is stable.
  source   String
  sourceId String

  title    String
  // Plain-text body used for search ranking + chat-visible snippets.
  body     String  @db.Text
  // Original HTML body if the upstream source had one, so an admin UI
  // can render the real formatting without another round-trip.
  bodyHtml String? @db.Text

  // Permalink back to the Mighty page so the chatbot can cite it.
  url       String?
  spaceId   String?
  spaceName String?

  // Lightweight tags (post_type, content_type, etc.) for filtering.
  tags String[]

  publishedAt DateTime?
  indexedAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([source, sourceId])
  @@index([source])
  @@index([spaceId])
  @@index([publishedAt])
}

model KnowledgeIngestRun {
  id         String    @id @default(cuid())
  // "running" | "success" | "error" | "partial"
  status     String    @default("running")
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  itemsSeen     Int @default(0)
  itemsUpserted Int @default(0)
  itemsFailed   Int @default(0)

  // Optional error text for the run overall (not per-item — those are logged).
  errorMessage String? @db.Text
  // Per-source breakdown: { "mighty:post": { seen, upserted, failed }, ... }
  sources      Json?
  // How the run was kicked off: "cron" | "admin" | "cli"
  trigger      String  @default("cron")

  @@index([startedAt])
  @@index([status])
}

// ============ COMMERCE: PRODUCTS, PURCHASES, ENTITLEMENTS, COMMISSIONS ============
// Built for a single-merchant marketplace: AIMS is the merchant of record
// for every transaction. Resellers are advanced affiliates — they earn a
// commission on purchases they drove (via attribution cookie or whitelabel
// page submit), but never hold the customer payment relationship.
//
// Lifecycle:
//   1. Product is defined in DB (Stripe price IDs attached)
//   2. User buys via Stripe Checkout → Purchase row created on webhook
//   3. Purchase grants Entitlement rows (synced from Product.entitlements)
//   4. If Purchase has referringResellerId → CommissionEvent (pending) fires
//   5. CommissionEvent flips to "payable" after a clawback window passes
//   6. Admin runs payout batch → Stripe Connect Transfer → "paid"
//   7. Refunds within window → CommissionEvent clawback row appended

model Product {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String? @db.Text
  // "tier"    — Member / Operator / Reseller progression packages
  // "tool"    — a la carte feature (chatbot-premium, voice-agent)
  // "addon"   — supplementary upsell tied to a tier
  type        String
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  // Stripe price IDs — any subset may be set. The checkout flow picks the
  // one that matches the user's chosen interval.
  stripePriceMonthly String?
  stripePriceAnnual  String?
  stripePriceOneTime String?

  // Entitlement keys this product grants when the purchase is active.
  // Examples: ["chatbot-premium", "voice-agent", "playbook-vault",
  //            "whitelabel-tools", "commission-tracking"]
  entitlements String[]

  // Default commission rate in basis points (10000 = 100%). Applied when
  // a reseller drove the purchase. 2000 = 20%, 0 = no commission tier.
  commissionBps Int @default(0)

  // If this product unlocks a role upgrade (e.g. CLIENT → RESELLER), set
  // the target role here. Webhook flips User.role on first purchase.
  grantsRole String?

  metadata Json?

  // Marketing video embed URL (Vimeo / Loom / YouTube / Screen Studio).
  // Rendered in the paywall overlay AND on the marketplace card so we
  // can sell each plan / add-on with a 60-second walkthrough instead of
  // pure copy. Optional — UI shows a placeholder while empty.
  marketingVideoUrl String?

  // For "tier" Products that act as recurring plans (free / pro / operator):
  // how many enrichment credits to grant the user every month at renewal.
  // For "addon" Products that are one-time credit packs: ignored here, see
  // creditsOneTime instead.
  creditsPerMonth Int @default(0)

  // For one-time credit-pack Products (type="addon"): how many credits to
  // grant immediately on checkout.session.completed. 0 means this is not
  // a credit pack.
  creditsOneTime Int @default(0)

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]

  @@index([type, isActive])
  @@index([sortOrder])
}

model Purchase {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  // Attribution — set ONCE on initial purchase from the cookie or form.
  // Renewals on the same subscription preserve this id forever (the
  // reseller earns lifetime commission on the customer they drove).
  referringResellerId String?
  referringReseller   User?   @relation("PurchaseAttribution", fields: [referringResellerId], references: [id])

  // Stripe object linkage — exactly one of these is the canonical id.
  stripeSubscriptionId    String? @unique
  stripeChargeId          String? @unique
  stripeCheckoutSessionId String? @unique
  stripeCustomerId        String?

  // "active" | "trialing" | "past_due" | "canceled" | "refunded" | "incomplete"
  status      String
  // Gross paid in cents (most recent transaction for subs).
  amountCents Int
  currency    String @default("usd")

  // "monthly" | "annual" | "one_time"
  intervalType String?

  startedAt DateTime  @default(now())
  endedAt   DateTime?
  cancelAt  DateTime?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commissions  CommissionEvent[]
  entitlements Entitlement[]

  @@index([userId])
  @@index([referringResellerId])
  @@index([status])
  @@index([productId])
}

model Entitlement {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Feature key, e.g. "chatbot-premium", "voice-agent". Strings are easier
  // to evolve than enums when product/tools change frequently.
  key String

  // Most recent purchase that re-granted this entitlement. Null if granted
  // by an admin override (free tier / comp / etc.).
  grantedByPurchaseId String?
  grantedBy           Purchase? @relation(fields: [grantedByPurchaseId], references: [id], onDelete: SetNull)

  grantedAt DateTime  @default(now())
  // null = lifetime (single-purchase products). For subs we set this to
  // the next billing-period end and refresh on each invoice.paid webhook.
  expiresAt DateTime?
  // Soft-delete on cancel/refund. Re-grant rather than create new row.
  revokedAt DateTime?

  // One row per (user, key). On overlapping grants from multiple products,
  // we keep this row and just point grantedByPurchaseId at the strongest.
  @@unique([userId, key])
  @@index([key])
  @@index([expiresAt])
}

model CommissionEvent {
  id String @id @default(cuid())

  resellerId String
  reseller   User   @relation("ResellerCommissions", fields: [resellerId], references: [id])

  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  // "initial_purchase" | "renewal" | "upgrade" | "clawback"
  type String

  // Amount the rate was applied against (gross transaction in cents).
  baseAmountCents Int
  // Rate at time of event in basis points (snapshotted from Product so a
  // future product-rate change doesn't retroactively adjust history).
  commissionBps   Int
  // Signed; negative for clawback. Always derivable from base * bps but
  // stored explicitly for fast aggregation queries.
  amountCents     Int
  currency        String @default("usd")

  // "pending" — within the clawback window (default 30 days)
  // "payable" — clawback window passed, ready to pay
  // "paid"    — Stripe Connect Transfer executed
  // "clawed_back" — refund landed before payable; this event nullifies an earlier one
  // "voided"  — admin manually nullified (chargeback, fraud)
  status           String
  payableAt        DateTime?
  paidAt           DateTime?
  stripeTransferId String?

  notes String? @db.Text

  createdAt DateTime @default(now())

  @@index([resellerId, status])
  @@index([status, payableAt])
  @@index([purchaseId])
}

// ============ PORTAL FEEDBACK / BUG REPORTS ============
// Centralized inbox for portal users (e.g. Katie) reporting bugs, ideas,
// or questions. Replaces the previous email-based flow so admins triage
// from /admin/feedback instead of an inbox.
model PortalFeedback {
  id         String  @id @default(cuid())
  reporterId String?
  reporter   User?   @relation("PortalFeedbackReporter", fields: [reporterId], references: [id], onDelete: SetNull)

  // Snapshot of reporter identity at submission time so the row stays
  // useful even if the User row is later deleted.
  reporterEmail String
  reporterName  String?

  category String // BUG | IDEA | QUESTION | OTHER
  title    String
  details  String @db.Text

  pageUrl   String?
  userAgent String?

  // NEW | TRIAGED | IN_PROGRESS | RESOLVED | WONT_FIX
  status    String  @default("NEW")
  adminNote String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([reporterId])
}

// ============ AUDIT QUIZ FUNNEL ============
//
// Per-operator brandable intake quizzes. Operators build a quiz from a
// pre-seeded AI Audit template, customize branding/questions inline,
// share a public link, and collect lead responses with AI-generated
// summaries. Admins see aggregate analytics across all workspaces.

model AuditQuiz {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation("AuditQuizOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  slug     String  @unique
  title    String
  subtitle String?
  ctaLabel String  @default("Take the Audit")

  // Branding overrides — falls back to operator's MemberProfile when null.
  logoUrl      String?
  brandColor   String?
  accentColor  String?
  customDomain String? // optional whitelabel host the operator wants the link to render under

  // Questions stored as JSON: Array<{ id, label, helper?, type, required?, options?[] }>
  // Keeping inline edits cheap — schema doesn't migrate every time we add a field type.
  questions Json

  successHeadline String?
  successMessage  String? @db.Text
  successCta      String?
  successCtaUrl   String?

  collectEmail  Boolean @default(true)
  emailRequired Boolean @default(true)

  isPublished Boolean   @default(true)
  archivedAt  DateTime?

  responses AuditResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([slug])
  @@index([createdAt])
}

model AuditResponse {
  id     String    @id @default(cuid())
  quizId String
  quiz   AuditQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  leadEmail   String?
  leadName    String?
  leadCompany String?
  leadPhone   String?
  leadRole    String?

  // Answers shape: { [questionId]: value }
  answers Json

  aiSummary     String?   @db.Text
  aiScore       Int?
  aiTags        String[]
  aiArms        Json?
  aiGeneratedAt DateTime?

  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  referer     String?
  userAgent   String?
  ip          String?

  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([quizId])
  @@index([leadEmail])
  @@index([createdAt])
}

// ============ ENRICHMENT CREDIT LEDGER ============

// Append-only ledger of every credit movement. Sources of credits:
//   - Initial trial grant on signup (+50)
//   - Monthly plan grants (+500 / +2000 / +10000 depending on tier)
//   - Stripe top-up purchases (+500 per $20)
//   - Refunds (e.g. when an enrichment errors mid-run, unused credits return)
// Sinks: enrichment operations (Places search, Hunter, Prospeo, etc.).
//
// `balanceAfter` is denormalized for fast audit/debug — given any tx row
// you can verify the running balance without summing the whole ledger.
model CreditTransaction {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount       Int // negative = debit (spend), positive = grant/refund
  reason       String // "enrichment-debit" | "places-search" | "monthly-grant" | "topup-purchase" | "refund-error" | "trial-grant"
  metadata     Json? // { dealId, source, operation, ... }
  balanceAfter Int // running balance after this tx applied
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([reason])
}

// ============ UNIVERSAL EVENT LAYER ============

// Append-only stream of every meaningful action across the platform.
// Single source of truth that powers: Today dashboard, daily digest,
// activity timelines, attribution, cohort analytics, playbook outcome
// tracking, and the morning-open habit.
//
// No FK on entityId so events survive entity deletion (audit history).
// `actorId` is the user who emitted (operator most often). `targetUserId`
// is optional — used when the event is "about" a different user (e.g.
// admin actions on a client).
model OperatorEvent {
  id           String   @id @default(cuid())
  actorId      String
  actor        User     @relation("OperatorEventActor", fields: [actorId], references: [id], onDelete: Cascade)
  targetUserId String?
  type         String // canonical event name — see EVENT_TYPES in src/lib/events/emit.ts
  entityType   String? // "ClientDeal" | "AuditQuiz" | "AuditResponse" | "Playbook" | etc.
  entityId     String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([actorId, type, createdAt])
  @@index([entityType, entityId])
  @@index([type, createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// PHASE 2 — productivity features (templates, sequences, client updates,
// recordings, booking)
// ────────────────────────────────────────────────────────────────────────────

/// Reusable template — emails, proposal sections, scripts, content drafts.
/// Variables like {{contact.firstName}} get merged at use-time.
model UserTemplate {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Type drives where the template surfaces:
  //   "email"    — AI Scripts, Sequences, Client Updates
  //   "proposal" — Proposal builder (header, scope, terms blocks)
  //   "script"   — Discovery / cold-call / follow-up scripts
  //   "content"  — Social, blog, newsletter
  //   "snippet"  — short reusable text (sigs, openers)
  type String

  title     String
  body      String   @db.Text
  /// Comma-list of variable names this template uses, for UI auto-complete.
  variables String[]
  /// Public templates are curated by the platform admins; private are
  /// owned by the user. Admin UI flips a row public.
  isPublic  Boolean  @default(false)
  tags      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, type])
  @@index([isPublic, type])
}

/// Multi-step cold outreach sequence definition.
model EmailSequence {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String
  /// "draft" | "active" | "paused"
  status       String  @default("draft")
  /// Whether to auto-pause the enrollment when the prospect replies.
  pauseOnReply Boolean @default(true)
  /// Optional from-name override; defaults to the user's name.
  fromName     String?

  steps       SequenceStep[]
  enrollments SequenceEnrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
}

/// One step within an EmailSequence. Steps run in `order` ascending; each
/// has a delay (in days) from the previous step's send.
model SequenceStep {
  id         String        @id @default(cuid())
  sequenceId String
  sequence   EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  order     Int
  delayDays Int    @default(0)
  subject   String
  body      String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sequenceId, order])
  @@index([sequenceId])
}

/// One contact's enrollment in a sequence. Tracks per-step send progress so
/// the cron worker (or "Send now" button) can pick up where it left off.
model SequenceEnrollment {
  id         String        @id @default(cuid())
  sequenceId String
  sequence   EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  // Owner of the enrollment (mirrors sequence.userId for query convenience).
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Optional link back to a CRM ClientDeal so replies can route to the deal.
  clientDealId String?

  // Recipient identity. We store inline (not just dealId) so a sequence can
  // enroll cold prospects who don't have a CRM row yet.
  recipientEmail String
  recipientName  String?

  /// 0-indexed pointer into `sequence.steps` ordered by `order`.
  /// When `currentStep === sequence.steps.length` the enrollment is done.
  currentStep    Int       @default(0)
  /// "active" | "paused" | "done" | "replied" | "stopped"
  status         String    @default("active")
  lastStepSentAt DateTime?
  nextSendAt     DateTime?
  repliedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sequenceId, status])
  @@index([userId, status])
  @@index([nextSendAt, status])
}

/// AI-generated weekly status email for an active retainer client.
model ClientUpdate {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Optional link to the deal this update is for.
  clientDealId String?

  /// "draft" — generated, not yet sent
  /// "sent"  — operator approved + sent
  /// "skipped" — operator skipped this week's update
  status String @default("draft")

  weekStartDate DateTime
  subject       String
  body          String    @db.Text
  /// JSON of the data slice we generated from (activity, invoices, content)
  /// so we can re-render or audit later.
  generatedFrom Json?
  sentAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status, weekStartDate])
}

/// Discovery call recording — transcript or audio upload + AI summary.
model CallRecording {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  clientDealId String?

  title           String
  /// Free-form name or paste of the source ("Zoom — Acme Co intro call").
  source          String?
  durationSeconds Int?

  /// Raw transcript pasted by user, or transcribed from upload.
  transcript    String  @db.Text
  /// AI-extracted structured summary: pains, budget, decision-makers, objections, action items.
  summary       Json?
  /// Pre-drafted follow-up email body.
  followUpDraft String? @db.Text

  /// "uploading" | "ready" — set "ready" once transcript + summary present.
  status String @default("ready")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

/// Per-user availability config for the branded booking page.
model BookingAvailability {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Public URL handle — e.g. "adam" → /book/adam
  handle   String  @unique
  isActive Boolean @default(true)

  /// Fixed meeting length in minutes.
  durationMinutes Int    @default(30)
  /// Buffer between meetings.
  bufferMinutes   Int    @default(15)
  /// IANA timezone, e.g. "America/Los_Angeles".
  timezone        String @default("America/Los_Angeles")

  /// JSON shape: { mon: [{start:"09:00",end:"17:00"}], tue: [...], ... }
  /// Empty array on a day = unavailable.
  weeklyHours Json

  /// Welcome copy on the public booking page.
  welcomeTitle String?
  welcomeBody  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A confirmed booking on someone's branded scheduler.
model Booking {
  id     String @id @default(cuid())
  userId String // operator (booking page owner)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Optional link to a CRM deal we auto-created.
  clientDealId String?

  inviteeName  String
  inviteeEmail String
  inviteePhone String?
  notes        String? @db.Text

  startAt DateTime
  endAt   DateTime
  /// "confirmed" | "canceled" | "no_show"
  status  String   @default("confirmed")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, startAt])
  @@index([startAt, status])
}

/// Admin-editable override for any email template that ships from
/// `src/lib/email/*`. The catalog of editable templates lives in
/// `src/lib/email/catalog.ts` keyed by stable `templateKey` strings —
/// this table just stores the customised subject + HTML body the team
/// has saved through /admin/email-templates.
///
/// Each `send*Email` helper passes its templateKey to `sendTrackedEmail`,
/// which looks up the most recent override and uses its subject/html
/// instead of the code defaults when one exists. Deleting a row reverts
/// to the hard-coded default with zero risk — defaults are always
/// available because they live in code.
model EmailTemplateOverride {
  id          String   @id @default(cuid())
  templateKey String   @unique
  /// Human-readable note saved alongside the edit ("Updated CTA copy").
  note        String?
  subject     String
  html        String   @db.Text
  /// Clerk user id of whoever last saved this override.
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([templateKey])
}
